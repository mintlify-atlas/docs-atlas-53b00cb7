  "keyFeatures": [
    "Multi-tenant architecture with path-based and subdomain routing",
    "Product catalog with menu sections, modifiers, and media",
    "Order management with real-time status updates and PDF receipts",
    "Booking and appointment system with service providers and reminders",
    "Marketing tools: coupons, campaigns, announcements, and loyalty programs",
    "AI-powered business profile optimization with budget control",
    "Filament admin panels for tenants and super admins",
    "REST API v1 with Sanctum auth, OTP, and social login",
    "Real-time broadcasting with Laravel Reverb and Web Push",
    "Modular monolith with DDD and Hexagonal/Ports-and-Adapters architecture",
    "Exportable reports (PDF and Excel)",
    "PWA support with offline capability"
  ],
  "publicApiSurface": [
